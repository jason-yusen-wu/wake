harness/eval/results/
harness/eval/reports/
harness/agent-loop/results/
# swebench's local eval harness writes here (run-relative)
logs/
# Rung-2 source-file cache (re-fetched from GitHub on demand)
probe/oracle/cache/
probe/oracle/results/
probe/oracle/reports/
# Rung-1 audit reports (regenerated by analyze.py)
probe/audit/reports/
# Pipeline step logs
run_all_logs/

# ── Stray swebench summary dumps (written to CWD by the eval harness) ──────────
*.phase8_*.json

# ── Editor / OS ────────────────────────────────────────────────────────────────
.DS_Store
.idea/
*.swp

# ── KEPT research artifacts (committed deliberately) ──────────────────────────
