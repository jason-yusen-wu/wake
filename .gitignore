/target
debug
**/*.rs.bk
*.pdb
**/mutants.out*/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# ── Third-party clones (vendored at setup time, never committed) ───────────────
